import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPost from '../components/BlogPost.astro';
const matches = import.meta.glob('./posts/*.md', { eager: true });
const allPosts = Object.values(matches);
// const allPosts = Object.values(
//   import.meta.glob("./posts/*.md", { eager: true })
// );
allPosts.map((post:any) => {
  console.log(post.frontmatter);
  console.log(post.url)
  console.log(post.file)
});

const pageTitle = 'My Astro Learning Blog';
---
<BaseLayout pageTitle={pageTitle}>
    <section id="blog">
        <h2>Learning Astro Adventures</h2>
        <p>This is where I will post about my journey learning Astro.</p>
        <ul>
            <!--li><a href="/posts/post-1/">Post 1</a></li>
            <li><a href="/posts/post-2/">Post 2</a></li>
            <li><a href="/posts/post-3/">Post 3</a></li-->
            <!-- {
                allPosts.map((post:any) => 
                    <li><a href={post.url}>{post.frontmatter.title}</a></li>
                )
            } -->
          {
            allPosts.map((post:any) => <BlogPost url={post.url} title={post.frontmatter.title} />)
          }
        </ul>      
    </section>
</BaseLayout>

