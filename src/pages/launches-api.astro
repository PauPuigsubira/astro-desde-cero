---
import BaseLayout from '../layouts/BaseLayout.astro';
import { type Albums, type AlbumDetail } from '../types/api_album';

const res:Albums = await fetch("https://jsonplaceholder.typicode.com/users/1/albums",
  {
    method: "GET",
    headers: { 
      "Content-Type": "application/json; charset=UTF-8"
    },
    // body: JSON.stringify({
    //   query: {},
    //   option: {
    //     sort: {
    //       albumId: "desc"
    //     },
    //     limit: 12,
    //   }
    // })
  }
)
.then(data => data.json());
//const res = await response.json();
console.log(JSON.stringify(res));
const pageTitle = "Fake Albums API";
---
<BaseLayout pageTitle={pageTitle}>
  <p>This is a test page for jsonplaceholder typicode API.</p>
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {res.map((item:AlbumDetail) => (
      <div
        class:list= {[
          "text-m font-semibold p-4 mr-2 px2.5 py-0.5 rounded",
          {
            "bg-gray-200" : item.id % 2 === 0,
            "bg-yellow-200" : item.id % 2 !== 0
          }
        ]}
      >
        <p>{item.id + " - " + item.title}</p>
      </div>
    ))}
  </div>
</BaseLayout>