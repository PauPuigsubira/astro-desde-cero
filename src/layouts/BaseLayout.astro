---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { ClientRouter } from "astro:transitions";

import '../styles/global.css';
const {pageTitle} = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link 
      rel="alternate"
      type="application/rss+xml"
      title="Learner Blog - Topic Astro"
      href={"/rss.xml" /*new URL("rss.xml", Astro.site)*/}
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <slot name="advertising">
      <section>
        <div class="border-2 border-gray-300 px-5 rounded-md p-4 m-4 bg-sky-500/50">
          <p>Anúnciate aqui con nosotros. Dale click <a href="">aqui</a> para más información</p>
        </div>
      </section>  
    </slot>
    <h1>{pageTitle}</h1>
    <slot />
    <!-- <Like postId="1" /> -->
    <Footer />
    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>

<style is:global>
  p {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    font-size: 1.2rem;
    line-height: 1.5;
    color: #115d70;
    margin: 0;
    padding: 0;
    text-align: left;
    text-wrap: balance;
  }
</style>