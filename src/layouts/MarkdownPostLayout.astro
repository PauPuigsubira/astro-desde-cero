---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const datePub = new Date(frontmatter.pubDate);
const dateDay = String(datePub.getDate()).padStart(2,'0');
const dateMonth = String(datePub.getMonth()+1).padStart(2,'0');
const dateYear = datePub.getFullYear();
const formatDate = `${dateDay}/${dateMonth}/${dateYear}`;

---
<BaseLayout pageTitle={frontmatter.title}>
  <!--meta charset="utf-8" /-->
  <!--h1>{frontmatter.title}</h1-->
  <p>Written by {frontmatter.author}</p>
  <p><i>Published on {formatDate}</i></p>
  <p><small><i>Published on {datePub.toString().slice(0,10)}</i></small></p>
  <p><em>{frontmatter.description}</em></p>
  <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} />
<slot />
</BaseLayout>
